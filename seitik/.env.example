# In .env kopieren. Diese Datei liegt NEBEN docker-compose.yaml.
# Compose liest sie sowohl für ${...} im yaml als auch via env_file im Container.

SECRET_KEY='hier-einen-langen-zufaelligen-string-einsetzen'
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

DB_ENGINE=django.db.backends.postgresql
DB_NAME=hermann_db
DB_USER=hermann
DB_PASSWORD=ein-sicheres-passwort
DB_HOST=db
DB_PORT=5432

# Nur für den Host, nicht für den Container:
WEB_BIND_IP=127.0.0.1
WEB_PORT=8000

# Beim Betrieb ohne HTTPS (z. B. lokal mit DEBUG=False):
SECURE_SSL_REDIRECT=False